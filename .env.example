# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database — get from Supabase dashboard > Settings > Database > Connection string
# Use the "Transaction" mode URI (port 6543) for DATABASE_URL
# Use the "Session" mode URI (port 5432) for DIRECT_URL
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-xx.pooler.supabase.com:5432/postgres

# Supabase service role (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email — get from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — generate a random string: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret
